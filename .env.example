# Nature Risk Environment Variables
# Copy to .env and fill in values

# MapTiler API key (free tier: https://cloud.maptiler.com/)
VITE_MAPTILER_KEY=

# Cloudflare Worker proxy URL (deployed worker endpoint)
VITE_PROXY_URL=

# Anthropic API key (optional — for direct Claude API calls in development)
# In production, the CF Worker holds the key as a secret
VITE_ANTHROPIC_KEY=
